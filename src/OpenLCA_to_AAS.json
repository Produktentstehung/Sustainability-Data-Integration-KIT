    {
        "id": "0eb852d89f33ea07",
        "type": "function",
        "z": "0fb9b33015556b16",
        "name": "Ready? → get impacts or wait",
        "func": "if (msg.payload.error) {\n  node.error(\"State error: \" + msg.payload.error.message, msg);\n  return null;\n}\n\nconst state = msg.payload.result;\nconst resultId = flow.get(\"resultId\");\n\nif (state?.isReady === true) {\n  flow.set(\"step\", \"get-impacts\");\n  msg.payload = {\n    jsonrpc: \"2.0\",\n    id: 3,\n    method: \"result/total-impacts\",\n    params: { \"@type\": \"Result\", \"@id\": resultId }\n  };\n  return [msg, null];\n} else {\n  flow.set(\"step\", \"check-state\");\n  msg.payload = {\n    jsonrpc: \"2.0\",\n    id: 2,\n    method: \"result/state\",\n    params: { \"@type\": \"Result\", \"@id\": resultId }\n  };\n  return [null, msg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1480,
        "y": 700,
        "wires": [
            [
                "6c518c2fe0795bd4"
            ],
            [
                "9c455e67ba09ba6b"
            ]
        ]
    },
    {
        "id": "9c455e67ba09ba6b",
        "type": "delay",
        "z": "0fb9b33015556b16",
        "name": "Wait 500ms",
        "pauseType": "delay",
        "timeout": "500",
        "timeoutUnits": "milliseconds",
        "rate": "",
        "nbRateUnits": "",
        "randomFirst": "",
