    {
        "id": "99f7bd762992eb08",
        "type": "function",
        "z": "0fb9b33015556b16",
        "name": "1. Start calculation",
        "func": "// Warteschlange aus dem Dropdown auslesen (enthält direkt die UUIDs)\nlet selectedMethodUUIDs = flow.get(\"selectedMethods\") || [];\nlet currentIndex = flow.get(\"methodQueueIndex\");\n\n// Erststart initialisieren\nif (currentIndex === undefined) {\n    currentIndex = 0;\n    flow.set(\"methodQueueIndex\", currentIndex);\n    flow.set(\"aggregatedPcfResults\", []); // Hier sammeln wir alle Ergebnisse\n}\n\n// Fallback, falls der Trigger ohne Auswahl betätigt wurde\nif (selectedMethodUUIDs.length === 0) {\n    node.error(\"Keine Impact Method im Dropdown ausgewählt!\", msg);\n    return null;\n}\n\n// Prüfen, ob alle ausgewählten Methoden berechnet wurden\nif (currentIndex >= selectedMethodUUIDs.length) {\n    // Schleife beendet -> Index zurücksetzen für den nächsten globalen Durchlauf\n    flow.set(\"methodQueueIndex\", undefined);\n    \n    // Die gesammelten Ergebnisse in den Payload schreiben\n    msg.payload = flow.get(\"aggregatedPcfResults\");\n    flow.set(\"step\", \"done\"); \n    \n    // Wir senden das Ergebnis exklusiv an den ZWEITEN Ausgang\n    return [null, msg];\n}\n\n// Aktuelle UUID für diesen Durchlauf holen und im Kontext sichern\nconst currentMethodUUID = selectedMethodUUIDs[currentIndex];\nconst currentMethodName = flow.get('selectedMethodNames')[currentIndex];\nflow.set(\"currentMethodUUID\", currentMethodUUID);\nflow.set('currentMethodName', currentMethodName);\n\nflow.set(\"step\", \"calculate\");\nmsg.url = \"http://localhost:8080\";\n\n// Deine vordefinierten Prozesse und Parameter-Redefinitionen\nconst processes = [\n  {\n    name: \"Bolzen\",\n    uuid: \"90291baa-d449-4afc-9d2a-01e8e650afd8\",\n    params: { Menge_Stahl_Bolzen: 0.00082, Menge_Aluminium_Bolzen: 0.00010, Energieverbrauch_Bolzen: 0.0035 }\n  },\n  {\n    name: \"Feder\",\n    uuid: \"fbe7bd7c-dfb7-4f81-ba55-be282f6460bf\",\n    params: { Menge_Stahl_Feder: 0.00046, Energieverbrauch_Feder: 0.0023 }\n  },\n  {\n    name: \"Gehäuse\",\n    uuid: \"099a8043-4cb5-46f3-936b-2525547b7430\",\n    params: { Menge_Kunststoff_Gehaeuse: 0.0084, Energieverbrauch_Gehaeuse: 0.015 }\n  },\n  {\n    name: \"Kappe\",\n    uuid: \"b27161b9-399f-4318-971c-333a38890cf2\",\n    params: { Menge_Kunststoff_Kappe: 0.0012, Energieverbrauch_Kappe: 0.003 }\n  },\n  {\n    name: \"Mine\",\n    uuid: \"df348398-e4b7-49f9-bd14-263d91b4fa03\",\n    params: { Menge_Kunststoff_Mine: 0.0008, Menge_Tinte_Mine: 0.001, Energieverbrauch_Mine: 0.004 }\n  }\n];\n\nconst parameterRedefs = [];\nfor (const proc of processes) {\n  for (const [paramName, paramValue] of Object.entries(proc.params)) {\n    parameterRedefs.push({\n      \"@type\": \"ParameterRedef\",\n      name: paramName,\n      value: paramValue,\n      context: { \"@type\": \"Process\", \"@id\": proc.uuid }\n    });\n  }\n}\n\n// JSON-RPC Payload zusammenbauen\nmsg.payload = {\n  jsonrpc: \"2.0\",\n  id: 1,\n  method: \"result/calculate\",\n  params: {\n    \"@type\": \"CalculationSetup\",\n    target: {\n      \"@type\": \"ProductSystem\",\n      \"@id\": \"78d8a79f-218d-4be9-bae4-06bca0ec5c66\"\n    },\n    impactMethod: {\n      \"@type\": \"ImpactMethod\",\n      \"@id\": currentMethodUUID // Direkte Nutzung der UUID aus dem Dropdown!\n    },\n    amount: 25,\n    parameterRedefs: parameterRedefs\n  }\n};\n\n// Berechnungsaufruf an den ERSTEN Ausgang senden\nreturn [msg, null];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1450,
        "y": 480,
        "wires": [
            [
                "6c518c2fe0795bd4"
            ],
            [
                "4b174e4b8c7c23f0"
            ]
        ]
    },
