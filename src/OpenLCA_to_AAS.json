    {
        "id": "2fbd9ff2f64732d8",
        "type": "function",
        "z": "0fb9b33015556b16",
        "name": "Format to Markdown",
        "func": "const results = msg.payload;\nmsg.results = results;\n\nif (!Array.isArray(results) || results.length === 0) {\n    msg.payload = \"<div style='color: var(--md-sys-color-error, #ff0000); font-weight: bold;'>⚠ Keine LCA-Ergebnisse zur Anzeige vorhanden.</div>\";\n    return msg;\n}\n\n// CSS-Styles für eine saubere Dashboard-Tabelle definieren\nlet html = `\n<style>\n    .lca-container { font-family: sans-serif; padding: 8px; }\n    .lca-title { margin-bottom: 4px; font-size: 1.4rem; font-weight: bold; }\n    .lca-meta { font-size: 0.9rem; color: #777; margin-bottom: 16px; }\n    .lca-method-section { margin-top: 24px; }\n    .lca-method-title { font-size: 1.15rem; font-weight: bold; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }\n    .lca-table { width: 100%; border-collapse: collapse; margin-bottom: 8px; background: transparent; }\n    .lca-table th { text-align: left; padding: 10px; font-weight: bold; border-bottom: 2px solid var(--v-border-color, #ccc); }\n    .lca-table td { padding: 8px 10px; border-bottom: 1px solid var(--v-border-color, #eee); }\n    .lca-table tr:hover { background-color: rgba(0,0,0,0.03); }\n    .text-right { text-align: right; }\n    .text-center { text-align: center; }\n</style>\n<div class=\"lca-container\">\n    <div class=\"lca-title\">📊 Ökobilanz-Auswertung (LCA Results)</div>\n    <div class=\"lca-meta\">\n        <strong>System:</strong> ${results[0].processName}<br>\n        <strong>Menge:</strong> ${results[0].targetOutput}<br>\n        <em>Berechnet am: ${new Date(results[0].calculatedAt).toLocaleString(\"de-DE\")}</em>\n    </div>\n`;\n\n// Schleife generiert NUR Tabellen für Methoden, die tatsächlich im Array stecken\nresults.forEach((res, index) => {\n    const methodName = res.impactMethodName || `Methode (${res.impactMethod.substring(0,8)}...)`;\n    \n    html += `\n    <div class=\"lca-method-section\">\n        <div class=\"lca-method-title\">🌍 ${index + 1}. ${methodName}</div>\n    `;\n    \n    if (!res.allImpacts || res.allImpacts.length === 0) {\n        html += `<p style=\"font-style: italic; color: #888;\">Keine Indikatoren für diese Methode vorhanden.</p></div>`;\n        return;\n    }\n\n    html += `\n        <table class=\"lca-table\">\n            <thead>\n                <tr>\n                    <th>Wirkungskategorie</th>\n                    <th class=\"text-right\">Wert</th>\n                    <th class=\"text-center\">Einheit</th>\n                </tr>\n            </thead>\n            <tbody>\n    `;\n    \n    res.allImpacts.forEach(imp => {\n        let formattedValue = imp.value;\n        if (typeof imp.value === 'number') {\n            if (imp.value === 0) {\n                formattedValue = \"0\";\n            } else if (imp.value < 0.001 && imp.value > 0) {\n                formattedValue = imp.value.toExponential(4);\n            } else {\n                formattedValue = imp.value.toLocaleString(\"de-DE\", { minimumFractionDigits: 2, maximumFractionDigits: 4 });\n            }\n        }\n        \n        html += `\n            <tr>\n                <td><strong>${imp.category}</strong></td>\n                <td class=\"text-right\">${formattedValue}</td>\n                <td class=\"text-center\" style=\"color: #666;\">${imp.unit}</td>\n            </tr>\n        `;\n    });\n    \n    html += `\n            </tbody>\n        </table>\n    </div>\n    `;\n});\n\nhtml += `</div>`;\n\nmsg.payload = html;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
