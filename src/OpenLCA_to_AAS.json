    {
        "id": "110c32a6dd7313c8",
        "type": "function",
        "z": "0fb9b33015556b16",
        "name": "Parse PCF → dispose",
        "func": "if (msg.payload && msg.payload.error) {\n  node.error(\"Impacts error: \" + msg.payload.error.message, msg);\n  return null;\n}\n\n// openLCA packt die Liste der Indikatoren in .result, falls es ein Standard-JSON-RPC-Response ist.\n// Falls nicht, nehmen wir das Payload direkt.\nlet impacts = [];\nif (msg.payload) {\n  if (Array.isArray(msg.payload.result)) {\n    impacts = msg.payload.result;\n  } else if (Array.isArray(msg.payload)) {\n    impacts = msg.payload;\n  }\n}\n\n// Dynamisches Mapping aller zurückgegebenen Impact-Kategorien\nconst parsedImpacts = impacts.map(r => ({\n  category: r.impactCategory?.name,\n  value: r.amount,\n  unit: r.impactCategory?.refUnit\n}));\n\n// Aktuelle Methoden-UUID aus dem Kontext ziehen\nconst activeMethodUUID = flow.get(\"currentMethodUUID\") || \"Unbekannte UUID\";\nconst activeMethodName = flow.get('currentMethodName') || \"Undefined\";\n\n// Einzel-Ergebnisobjekt aufbauen\nconst singleResult = {\n  processName: \"LCA Prozess: Kugelschreiber TRACEpen\",\n  processUUID: \"78d8a79f-218d-4be9-bae4-06bca0ec5c66\",\n  impactMethod: activeMethodUUID,\n  impactMethodName: activeMethodName,\n  targetOutput: \"25 Stück\",\n  allImpacts: parsedImpacts, // Jetzt prall gefüllt!\n  calculatedAt: new Date().toISOString()\n};\n\n// In das globale Array im Flow-Kontext pushen\nlet aggregatedResults = flow.get(\"aggregatedPcfResults\") || [];\naggregatedResults.push(singleResult);\nflow.set(\"aggregatedPcfResults\", aggregatedResults);\n\n// Index für die Warteschlange um 1 erhöhen\nlet currentIndex = flow.get(\"methodQueueIndex\") || 0;\nflow.set(\"methodQueueIndex\", currentIndex + 1);\n\n// Speicherbereinigung in openLCA einleiten\nflow.set(\"step\", \"dispose\");\nmsg.payload = {\n  jsonrpc: \"2.0\",\n  id: 4,\n  method: \"result/dispose\",\n  params: { \"@type\": \"Result\", \"@id\": flow.get(\"resultId\") }\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1480,
        "y": 840,
        "wires": [
            [
                "6c518c2fe0795bd4"
            ]
        ]
    },
