    {
        "id": "b3047e0ddd50cbfd",
        "type": "function",
        "z": "0fb9b33015556b16",
        "name": "Store result ID → check state",
        "func": "if (msg.payload.error) {\n  node.error(\"Calculate error: \" + msg.payload.error.message, msg);\n  return null;\n}\n\nconst resultId = msg.payload.result?.[\"@id\"];\nif (!resultId) {\n  node.error(\"No result ID returned: \" + JSON.stringify(msg.payload), msg);\n  return null;\n}\n\nflow.set(\"resultId\", resultId);\nflow.set(\"step\", \"check-state\");\n\nmsg.payload = {\n  jsonrpc: \"2.0\",\n  id: 2,\n  method: \"result/state\",\n  params: { \"@type\": \"Result\", \"@id\": resultId }\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1480,
        "y": 600,
        "wires": [
