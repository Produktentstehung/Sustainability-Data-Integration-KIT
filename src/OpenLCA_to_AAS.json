    {
        "id": "a02869036e4113b1",
        "type": "function",
        "z": "0fb9b33015556b16",
        "name": "refill submodel",
        "func": "// Ergebnisse robust holen (falls msg.results an dieser Stelle nicht mehr vorhanden ist)\nconst results = msg.results || flow.get('aggregatedPcfResults') || [];\n\nmsg.ilcdSubmodel = flow.get('ilcdSubmodel');\n\nif (msg.payload && msg.payload.submodelElements && msg.payload.submodelElements[0]) {\n\n    const lcaIteration = msg.payload.submodelElements[0].value[0];\n\n    // set SMC id\n    lcaIteration.idShort = \"PLM\";\n\n    // set SMC elements\n    lcaIteration.value[0].value = \"PLM\";                        // DataSource\n    lcaIteration.value[1].value = results[0]?.calculatedAt;     // TimeOfLCA\n    lcaIteration.value[2].value = msg.partWeight;               // WeightOfPart\n    lcaIteration.value[3].value = results[0]?.targetOutput;     // TargetOutput\n    // lcaIteration.value[2] -> WeightOfPart, ggf. separat befüllen\n\n    // Einfügen der SML für jede genutzte LCIA Method\n    const lciaMethodsSML = lcaIteration.value.find(el => el.idShort === \"LCIAMethods\");\n\n    if (lciaMethodsSML) {\n        lciaMethodsSML.value = results.map(result => {\n            const methodName = sanitizeIdShort(result.impactMethodName || result.impactMethod);\n\n            return {\n                modelType: \"SubmodelElementCollection\",\n                idShort: methodName,\n                value: (result.allImpacts || []).map(impact => ({\n                    modelType: \"SubmodelElementCollection\",\n                    idShort: sanitizeIdShort(impact.category),\n                    value: [\n                        {\n                            modelType: \"Property\",\n                            valueType: \"xs:double\",\n                            idShort: \"Value\",\n                            value: impact.value != null ? String(impact.value) : \"\"\n                        },\n                        {\n                            modelType: \"Property\",\n                            valueType: \"xs:string\",\n                            idShort: \"Unit\",\n                            value: impact.unit || \"\"\n                        }\n                    ]\n                }))\n            };\n        });\n    } else {\n        node.warn(\"SML 'LCIAMethods' im Submodell nicht gefunden!\");\n    }\n}\n\nreturn msg;\n\n// Hilfsfunktion: erzeugt gültige idShort-Werte (AAS: keine Leerzeichen/Sonderzeichen, nicht mit Ziffer beginnend)\nfunction sanitizeIdShort(str) {\n    if (!str) return \"Unbekannt\";\n    return str.toString()\n        .trim()\n        .replace(/[^A-Za-z0-9_]/g, \"_\")\n        .replace(/^[0-9]/, \"_$&\");\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
